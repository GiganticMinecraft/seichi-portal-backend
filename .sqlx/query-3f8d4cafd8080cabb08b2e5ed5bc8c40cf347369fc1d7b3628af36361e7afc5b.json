  "query": "\n                    SELECT id, user_id, reason, restricted_by, restricted_at, expires_at\n                    FROM answer_submission_restrictions\n                    WHERE user_id = ?\n                      AND lifted_at IS NULL\n                      AND (expires_at IS NULL OR expires_at > UTC_TIMESTAMP(6))\n                    ORDER BY restricted_at DESC\n                    LIMIT 1\n                    ",
