{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "platformAutomerge": true,
  "enabledManagers": [
    "cargo",
    "rust-toolchain"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "cargo"
      ],
      "rangeStrategy": "bump"
    }
  ]
}
